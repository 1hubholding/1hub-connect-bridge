{
  "name": "onehub-connect-bridge",
  "version": "1.0.0",
  "description": "Flutter WebView bridge for React/TypeScript",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
